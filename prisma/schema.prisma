// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DATABASE_DIRECT_URL")
  relationMode      = "prisma"
}

enum Role {
  ADMIN
  BUSINESS_OWNER
  STAFF
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(BUSINESS_OWNER)
  businesses    Business[]
  blogPosts     BlogPost[]
  termsAccepted Boolean   @default(false)
  termsAcceptedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Business {
  id                 String             @id @default(uuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id])
  inn                String             @unique
  ogrn               String?
  kpp                String?
  legalName          String
  address            String
  phone              String?
  contactPerson      String?
  businessType       String?            // ip, ooo, self
  businessCategory   String?            // cafe, retail, etc.
  bankName           String?
  bik                String?
  settlementAccount  String?
  corrAccount        String?
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionExpiresAt DateTime?
  trialEndsAt        DateTime?
  rebillId           String?            // T-Bank RebillId for recurring payments
  currentPlanSlug    String?            // e.g., 'business', 'content', 'business-plus'
  locations          Location[]
  playlists          Playlist[]
  licenses           License[]
  playLogs           PlayLog[]
  payments           Payment[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("businesses")
}

model Location {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  name       String
  address    String
  deviceId   String?   @unique
  playLogs   PlayLog[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("locations")
}

model Track {
  id         String    @id @default(uuid())
  title      String
  artist     String
  fileUrl    String
  duration   Int       // in seconds
  bpm        Int?
  genre      String?   @default("Unknown")
  moodTags   String[]  // Prisma supports arrays in Postgres
  isExplicit Boolean   @default(false)
  isFeatured Boolean   @default(false)
  energyLevel Int?
  playLogs    PlayLog[]
  playlists   PlaylistTrack[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("tracks")
}

model Playlist {
  id             String    @id @default(uuid())
  businessId     String?   // Global playlists if null
  business       Business? @relation(fields: [businessId], references: [id])
  name           String
  tracks         PlaylistTrack[]
  scheduleConfig Json?           // { "monday": [{ "start": "09:00", "playlist_id": 1 }] }
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(uuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  trackId    String
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

model PlayLog {
  id         String   @id @default(uuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  trackId    String
  track      Track    @relation(fields: [trackId], references: [id])
  playedAt   DateTime @default(now())

  @@map("play_logs")
}

model License {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  licenseNumber String @unique
  signingName  String
  issuedAt     DateTime @default(now())
  expiresAt    DateTime
  validFrom    DateTime
  validTo      DateTime
  totalCost    Float    @default(0)
  pdfUrl       String
  createdAt    DateTime @default(now())

  @@map("licenses")
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  imageUrl    String
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  views       Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        BlogPostTag[]

  @@index([slug])
  @@index([categoryId])
  @@index([published])
  @@map("blog_posts")
}

model BlogCategory {
  id    String @id @default(uuid())
  name  String @unique
  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPostTag {
  id        String @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagName   String

  @@index([postId])
  @@index([tagName])
  @@map("blog_post_tags")
}

model Payment {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  amount        Int      // in kopeks (kopeyki)
  status        String   // AUTHORIZED, CONFIRMED, REJECTED, etc.
  tbankPaymentId String? @unique
  orderId       String   @unique
  recurrent     Boolean  @default(false)
  rebillId      String?
  errorCode     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("payments")
}
